   "source": [
    "import numpy as np\n",
    "\n",
    "# Raw logits\n",
    "scores = np.array([3.2, 1.3, 0.2, 0.8])\n",
    "print(scores)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "6ba98098",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Probability distribution: [0.77514955 0.11593805 0.03859242 0.07031998]\n"
     ]
    }
   ],
   "source": [
    "# Compute softmax (no loop)\n",
    "exp_scores = np.exp(scores)\n",
    "softmax = exp_scores / np.sum(exp_scores)\n",
    "print(\"Probability distribution:\", softmax)"
   ]
  },
